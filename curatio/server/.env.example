# --- Local development -------------------------------------------------------
# Path to the fine-tuned BioBERT model directory (local dev only).
MODEL_PATH=../../../fine-tuned-biobert/fine_tuned_biobert_triage-20260602T132911Z-3-001/fine_tuned_biobert_triage

# URL of the Python ML service. Locally this is uvicorn on 8001.
# In production set this to the Hugging Face Space URL, e.g.
#   https://your-username-curatio-ml.hf.space
ML_SERVICE_URL=http://127.0.0.1:8001
ML_PORT=8001

# Express API port (Render injects its own PORT in production).
PORT=5000

# Confidence threshold below which a case is flagged as a Bayesian fallback candidate.
CONFIDENCE_THRESHOLD=0.85

# --- Production (Render) ------------------------------------------------------
# Comma-separated list of allowed browser origins (your Vercel client URL).
# Example: https://curatio.vercel.app
CLIENT_URL=
